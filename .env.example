# Copy this file to .env (which is gitignored) before running the gateway.
#   cp .env.example .env
#
# Admin credentials for your local Ignition gateway. Change them if you like;
# the defaults are fine for a throwaway lab gateway.
GATEWAY_ADMIN_USERNAME=admin
GATEWAY_ADMIN_PASSWORD=password

# Optional — lets `ops/scan.sh` tell the gateway to pick up project-file changes
# without a restart. Create a key once in the gateway UI (http://localhost:8088):
#   Config → Security → API Keys → Create  (give it Project Scan permission)
# then paste the value here. Leave blank to skip scanning (restart instead).
IGNITION_API_KEY=

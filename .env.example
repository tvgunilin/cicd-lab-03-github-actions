# Copy this file to .env (which is gitignored) before running the gateway.
#   cp .env.example .env
#
# Admin credentials for your local Ignition gateway. Change them if you like;
# the defaults are fine for a throwaway lab gateway.
GATEWAY_ADMIN_USERNAME=admin
GATEWAY_ADMIN_PASSWORD=password

# Optional — lets `scripts/scan.sh` tell the gateway to pick up project-file and
# gateway-config changes without a restart. One-time setup in the gateway UI
# (http://localhost:8088), because the scan API checks gateway write permission:
#   1. Config → Security → Security Levels: add a custom level, e.g. "Scan"
#   2. Config → Security → Security Settings: add it to Gateway Write Permissions
#   3. Config → Security → API Keys → Create: grant the "Scan" level, and disable
#      "Require secure connections for API Keys" (this lab's gateway is plain http)
# Paste the full generated key (it looks like <name>:<secret>) here.
# Leave blank to skip scanning (restart instead).
IGNITION_API_KEY=
